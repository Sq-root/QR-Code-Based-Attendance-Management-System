# ─────────────────────────────────────────────────────────────
# Environment configuration template
# ─────────────────────────────────────────────────────────────
# This project uses Vite's mode-based env files:
#
#   .env.development   -> loaded by `npm run dev`   (development mode)
#   .env.production    -> loaded by `npm run build` (production mode)
#   .env               -> optional LOCAL overrides (git-ignored)
#
# Both .env.development and .env.production are committed and shared.
# Copy a value here to .env only when you need a machine-local override.
# Secrets must NOT be committed — put them in .env.*.local instead.

# Base URL of the attendance backend API (keep the trailing slash)
VITE_API_URL=https://your-backend-host/api/v1/

# WAHA (WhatsApp HTTP API) base URL
VITE_WAHA_URL=http://localhost:3000

# Event session id (grab from the backend startup logs)
VITE_EVENT_SESSION_ID=replace-with-session-id-from-backend-logs
